generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ AUTH ============
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(SPECTATOR)
  phone     String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  ADMIN
  ORGANIZER
  PLAYER
  SPECTATOR
}

// ============ TEAMS ============
model Team {
  id        String   @id @default(cuid())
  name      String
  shortName String
  color     String
  colorLight String
  captain   String
  logo      String
  wins      Int      @default(0)
  losses    Int      @default(0)
  draws     Int      @default(0)
  points    Int      @default(0)
  nrr       String   @default("0.000")
  matchesPlayed Int  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  players   Player[]
  fixtures1 Fixture[] @relation("Team1")
  fixtures2 Fixture[] @relation("Team2")

  @@map("teams")
}

// ============ PLAYERS ============
model Player {
  id        String   @id @default(cuid())
  name      String
  teamId    String
  role      String   @default("Batsman")
  matches   Int      @default(0)
  runs      Int      @default(0)
  wickets   Int      @default(0)
  avg       String   @default("0.00")
  sr        String   @default("0.00")
  bestBatting String @default("-")
  bestBowling String @default("-")
  isCaptain Boolean  @default(false)
  teamColor String
  teamShort String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("players")
}

// ============ FIXTURES ============
model Fixture {
  id          String   @id @default(cuid())
  matchNumber Int
  team1Id     String
  team2Id     String
  date        String
  time        String
  venue       String
  status      FixtureStatus @default(UPCOMING)
  score       String?
  result      String?
  // Live score structured fields
  battingTeam Int?       // 1 or 2 — which team is currently batting
  team1Score  Int?       // Team 1 runs
  team1Wickets Int?      // Team 1 wickets fallen
  team1Overs  String?   // Team 1 overs bowled (e.g. "5.3")
  team2Score  Int?       // Team 2 runs
  team2Wickets Int?      // Team 2 wickets fallen
  team2Overs  String?   // Team 2 overs bowled (e.g. "3.2")
  striker     String?   // Current striker batsman name
  nonStriker  String?   // Current non-striker batsman name
  bowler      String?   // Current bowler name
  strikerRuns Int?       // Striker individual runs
  strikerBalls Int?      // Striker balls faced
  nonStrikerRuns Int?    // Non-striker individual runs
  nonStrikerBalls Int?   // Non-striker balls faced
  bowlerRuns  Int?       // Bowler runs conceded
  bowlerWickets Int?     // Bowler wickets taken
  bowlerOvers String?   // Bowler overs bowled
  thisOver    String?   // Current over ball-by-ball (e.g. "1 0 4 2")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team1 Team @relation("Team1", fields: [team1Id], references: [id])
  team2 Team @relation("Team2", fields: [team2Id], references: [id])

  @@map("fixtures")
}

enum FixtureStatus {
  COMPLETED
  LIVE
  UPCOMING
}

// ============ GALLERY ============
model GalleryImage {
  id        String   @id @default(cuid())
  title     String
  category  String
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gallery_images")
}

// ============ TOURNAMENT SETTINGS ============
model TournamentSetting {
  id            String @id @default(cuid())
  key           String @unique
  value         String
  updatedAt     DateTime @updatedAt

  @@map("tournament_settings")
}
